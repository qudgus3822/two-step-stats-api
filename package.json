{
  "name": "two-step-stats-api",
  "version": "0.1.0",
  "description": "농구 동호회 엑셀 기록지를 데이터화하여 박스스코어/랭킹을 서빙하는 NestJS API 서버",
  "author": "김병현",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "sample": "ts-node scripts/make-sample-xlsx.ts",
    "check": "ts-node scripts/check-pipeline.ts",
    "check:legacy": "ts-node scripts/check-legacy-import.ts",
    "import:legacy": "ts-node scripts/import-legacy-xlsx.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/serve-static": "^4.0.2",
    "@prisma/client": "^5.19.1",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "prisma": "^5.19.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
